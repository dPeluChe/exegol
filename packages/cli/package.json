{
  "name": "@exegol/cli",
  "version": "0.4.0",
  "private": true,
  "description": "Exegol CLI — query agents, projects, and search from the terminal",
  "bin": {
    "exegol": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:better-sqlite3 --external:libsql --banner:js=\"#!/usr/bin/env node\"",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "libsql": "^0.5.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tsx": "^4.0.0"
  }
}
