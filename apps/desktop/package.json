{
  "name": "@exegol/desktop",
  "version": "0.1.0",
  "description": "Desktop app for orchestrating AI coding agents",
  "author": "Antonio <antonio@iteris.tech>",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --config electron-builder.ts --publish never",
    "package:mac": "electron-vite build && electron-builder --config electron-builder.ts --mac --publish never",
    "package:win": "electron-vite build && electron-builder --config electron-builder.ts --win --publish never",
    "package:linux": "electron-vite build && electron-builder --config electron-builder.ts --linux --publish never",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@trpc/server": "^11.0.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "libsql": "^0.5.0",
    "node-pty": "^1.0.0",
    "nanoid": "^5.0.0",
    "croner": "^9.0.0",
    "electron-updater": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@exegol/shared": "workspace:*",
    "@exegol/ui": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "zustand": "^5.0.0"
  }
}
