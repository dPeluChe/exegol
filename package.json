{
  "name": "exegol",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run build:rust && turbo run dev",
    "dev:ui": "turbo run dev",
    "build": "turbo run build",
    "build:rust": "cd packages/core-rust && npx napi build --platform --release",
    "rebuild:native": "bun run build:rust && npx @electron/rebuild -v 41.0.2 -m . -o node-pty",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "typecheck": "turbo run typecheck",
    "test": "cd apps/desktop && vitest run",
    "test:watch": "cd apps/desktop && vitest",
    "test:coverage": "cd apps/desktop && vitest run --coverage"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "bun@1.2.0",
  "engines": {
    "node": ">=20"
  }
}
